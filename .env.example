# Auth0 (existing tenant — create a Regular Web Application)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Session encryption secret: openssl rand -hex 32
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# Optional: comma-separated list of emails allowed in (blocks other Auth0 signups)
ALLOWED_EMAILS=you@example.com

# Cosmos DB (existing instance)
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=
COSMOS_TRACKS_CONTAINER=tracks
COSMOS_CHORDPRO_CONTAINER=chordpro
COSMOS_PLAYLISTS_CONTAINER=playlists
